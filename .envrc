# .envrc — automatic environment for direnv + uv
echo "🔄 Setting up fastcontainer environment..."

# Sync the environment (creates .venv + installs everything from pyproject.toml)
uv sync --locked --quiet || true

# Add the virtualenv to PATH
PATH_add .venv/bin

# Optional: tell tools where the venv is (some editors like it)
export VIRTUAL_ENV="$PWD/.venv"
